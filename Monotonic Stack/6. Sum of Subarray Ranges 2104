class Solution {
public:
    long long subArrayRanges(vector<int>& nums) {

        int n = nums.size();

        long long minSum = 0;
        long long maxSum = 0;

        stack<int> st;

        // ---------- Minimum Contribution ----------

        for(int i = 0; i <= n; i++) {

            while(!st.empty() &&
                  (i == n || nums[st.top()] >= nums[i])) {

                int idx = st.top();
                st.pop();

                int prev =
                    st.empty() ? -1 : st.top();

                long long left = idx - prev;
                long long right = i - idx;

                minSum += 1LL * nums[idx] * left * right;
            }

            st.push(i);
        }

        while(!st.empty()) st.pop();

        

        for(int i = 0; i <= n; i++) {

            while(!st.empty() &&
                  (i == n || nums[st.top()] <= nums[i])) {

                int idx = st.top();
                st.pop();

                int prev =
                    st.empty() ? -1 : st.top();

                long long left = idx - prev;
                long long right = i - idx;

                maxSum += 1LL * nums[idx] * left * right;
            }

            st.push(i);
        }

        return maxSum - minSum;
    }
};

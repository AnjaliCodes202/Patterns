class Solution {
public:
    int maxWidthRamp(vector<int>& nums) {
        stack<int>st;
        int n = nums.size();
        for(int i=0; i<n; i++){  
            if(st.empty() || nums[st.top()]>nums[i]) st.push(i);
        }
        int mx=0;
        int p;
        for(int j=n-1;j>=0; j--){
            while(!st.empty() && nums[st.top()]<=nums[j]){
                 p=st.top();
                 st.pop();
            }
            mx = max(mx,(j-p));
            if(st.empty()) break;
        }
        return mx;
    }
};

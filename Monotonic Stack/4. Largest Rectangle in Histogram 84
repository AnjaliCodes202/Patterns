class Solution {
public:
    int largestRectangleArea(vector<int>& heights) {
        stack<int> st;
        int n = heights.size();
        long long ans = 0;
        for (int i = 0; i <= n; i++) {
            while (!st.empty() && (i == n || heights[st.top()] >= heights[i])) {
                int h = heights[st.top()];
                st.pop();
                int right = i;
                int left;
                if (st.empty())
                    left = -1;
                else
                    left = st.top();
                long long width = right - left - 1;
                ans = max(ans, width * h);
            }
            st.push(i);
        }
        return ans;
    }
};

//------------------------logic is correct but implementation is not-----------------------
class Solution {
public:
    vector<double> medianSlidingWindow(vector<int>& nums, int k) {

        priority_queue<int> small; 
        priority_queue<int, vector<int>, greater<int>> large; 

        unordered_map<int,int> delayed;

        int smallSize = 0;
        int largeSize = 0;

    
        for(int i=0;i<k;i++){

            if(small.empty() || nums[i] <= small.top()){
                small.push(nums[i]);
                smallSize++;
            }
            else{
                large.push(nums[i]);
                largeSize++;
            }

            while(smallSize > largeSize + 1){
                large.push(small.top());
                small.pop();
                smallSize--;
                largeSize++;
            }

            while(smallSize < largeSize){
                small.push(large.top());
                large.pop();
                smallSize++;
                largeSize--;
            }
        }

        vector<double> ans;

        if(k&1)
            ans.push_back((double)small.top());
        else
            ans.push_back(((double)small.top() + (double)large.top())/2.0);

        for(int r=k;r<nums.size();r++){

            int incoming = nums[r];
            int outgoing = nums[r-k];

            delayed[outgoing]++;

            if(outgoing <= small.top())
                smallSize--;
            else
                largeSize--;

   
            if(incoming <= small.top()){
                small.push(incoming);
                smallSize++;
            }
            else{
                large.push(incoming);
                largeSize++;
            }

      
            while(smallSize > largeSize + 1){

                large.push(small.top());
                small.pop();

                smallSize--;
                largeSize++;

                while(!small.empty() &&
                      delayed[small.top()] > 0){

                    delayed[small.top()]--;
                    if(delayed[small.top()] == 0)
                        delayed.erase(small.top());

                    small.pop();
                }
            }

            while(smallSize < largeSize){

                small.push(large.top());
                large.pop();

                smallSize++;
                largeSize--;

                while(!large.empty() &&
                      delayed[large.top()] > 0){

                    delayed[large.top()]--;
                    if(delayed[large.top()] == 0)
                        delayed.erase(large.top());

                    large.pop();
                }
            }

          
            while(!small.empty() &&
                  delayed[small.top()] > 0){

                delayed[small.top()]--;

                if(delayed[small.top()] == 0)
                    delayed.erase(small.top());

                small.pop();
            }

            while(!large.empty() &&
                  delayed[large.top()] > 0){

                delayed[large.top()]--;

                if(delayed[large.top()] == 0)
                    delayed.erase(large.top());

                large.pop();
            }

            if(k&1)
                ans.push_back((double)small.top());
            else
                ans.push_back(((double)small.top() + (double)large.top())/2.0);
        }

        return ans;
    }
};

class Solution {
public:
    typedef pair<long long,int>p;
    int mostBooked(int n, vector<vector<int>>& meetings) {
        priority_queue<int,vector<int>,greater<int>>available;
        priority_queue<p,vector<p>,greater<p>>occupied;
        unordered_map<int,int>freq;
        sort(meetings.begin(),meetings.end());
        for(int i=0; i<n; i++){
            available.push(i);
        }
        long long t=0;
        for(int i=0; i<meetings.size(); i++){
            t = max(t,(long long)meetings[i][0]);
            while(!occupied.empty() && occupied.top().first<=t){
                available.push(occupied.top().second);
                occupied.pop();
            }
            if(available.empty()){
                auto [time,room] = occupied.top();
                occupied.pop();
                t = time;
                available.push(room);
            }
            
            int room = available.top();
            available.pop();
            freq[room]++;
            occupied.push({t+(long long)(meetings[i][1]-meetings[i][0]),room});
        }

        int maxfreq=0,room=-1;
        for(int i=0; i<n; i++){
            if(maxfreq<freq[i]){
                room=i;
                maxfreq=freq[i];
            }
        }
        return room;

    }
};

/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    
    int count;
    void palindrome(TreeNode* root, int path){
        if(!root) return;
        if(!root->left && !root->right){
            path^=(1<<root->val);
            if((path & path-1)==0){
                count++;
            }
            return;
        }
        path^=(1<<root->val);
        palindrome(root->left,path);
        palindrome(root->right,path);
    }

    int pseudoPalindromicPaths (TreeNode* root) {
        count=0;
        palindrome(root,0);
        return count;
    }
};





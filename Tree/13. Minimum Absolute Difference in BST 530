    int getMinimumDifference(TreeNode* root) {
        stack<TreeNode*>st;
        TreeNode* prev = nullptr;
        int mndiff = INT_MAX;
        TreeNode* curr = root;
        while(curr || !st.empty()){
            while(curr){
                st.push(curr);
                curr = curr->left;
            }
            curr = st.top();
            st.pop();
            if(prev){
                mndiff = min(mndiff,abs(prev->val-curr->val));
            }
            prev = curr;
            curr = curr->right;
        }
        return mndiff;
    }
};

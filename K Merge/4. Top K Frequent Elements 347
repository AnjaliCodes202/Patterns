class Solution {
public:
    vector<int> topKFrequent(vector<int>& nums, int k) {
        unordered_map<int,int>mp;
        int n = nums.size();
        for(int i=0; i<n; i++){
            mp[nums[i]]++;
        }
        priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>>pq;
        for(auto p: mp){
            pq.push({p.second,p.first});
            if(pq.size()>k) pq.pop();
        }
        vector<int>result;
        while(!pq.empty()){
           auto [m,n]  = pq.top();
           pq.pop();
           result.push_back(n);
        }
        return result;
    }
};
